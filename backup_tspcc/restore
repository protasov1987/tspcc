#!/usr/bin/env bash
set -euo pipefail

BACKUP_ROOT="/backup_tspcc"
SITE_NAME="sql.tspcc.ru"
APP_DIR="/var/www/sql.tspcc.ru"
ENV_FILE="/etc/tspcc/sql.tspcc.ru.env"
DATA_DIR="${APP_DIR}/data"
STORAGE_DIR="${APP_DIR}/storage"
APP_OWNER="www-data:www-data"

usage() {
  cat >&2 <<'USAGE'
Usage:
  /backup_tspcc/restore backup_DDMMYYYY_HHMM

Example:
  /backup_tspcc/restore backup_02052026_1141

Environment:
  TSPCC_RESTORE_YES=1        Skip interactive confirmation.
  TSPCC_RESTORE_KEEP_TMP=1   Keep temporary staging directory for debugging.

This command is destructive: it drops/recreates the target MySQL database and
replaces current runtime data/storage files with files from the selected backup.
USAGE
}

log() {
  echo "[RESTORE] $*"
}

fail() {
  echo "[RESTORE][FAIL] $*" >&2
  exit 1
}

require_cmd() {
  command -v "$1" >/dev/null 2>&1 || fail "Required command not found: $1"
}

require_file() {
  local path="$1"
  [ -f "$path" ] || fail "Required file not found: $path"
}

require_dir() {
  local path="$1"
  [ -d "$path" ] || fail "Required directory not found: $path"
}

safe_backup_id() {
  local value="$1"
  [[ "$value" =~ ^backup_[0-9]{8}_[0-9]{4}$ ]] || fail "Backup name must match backup_DDMMYYYY_HHMM: $value"
}

safe_mysql_identifier() {
  local value="$1"
  [[ "$value" =~ ^[A-Za-z0-9_]+$ ]] || fail "Unsafe MySQL database name: $value"
}

mysql_exec() {
  local sql="$1"
  MYSQL_PWD="$TSPCC_DB_MIGRATION_PASSWORD" mysql \
    --protocol=TCP \
    --host="$TSPCC_DB_HOST" \
    --port="$TSPCC_DB_PORT" \
    --user="$TSPCC_DB_MIGRATION_USER" \
    --default-character-set=utf8mb4 \
    --batch \
    --raw \
    --execute="$sql"
}

restore_sql() {
  local sql_dump="$1"

  safe_mysql_identifier "$TSPCC_DB_NAME"
  log "Dropping and recreating MySQL database: $TSPCC_DB_NAME"
  mysql_exec "DROP DATABASE IF EXISTS \`$TSPCC_DB_NAME\`; CREATE DATABASE \`$TSPCC_DB_NAME\` CHARACTER SET utf8mb4 COLLATE utf8mb4_0900_ai_ci;"

  log "Importing SQL dump: $sql_dump"
  MYSQL_PWD="$TSPCC_DB_MIGRATION_PASSWORD" mysql \
    --protocol=TCP \
    --host="$TSPCC_DB_HOST" \
    --port="$TSPCC_DB_PORT" \
    --user="$TSPCC_DB_MIGRATION_USER" \
    --default-character-set=utf8mb4 \
    "$TSPCC_DB_NAME" < "$sql_dump"
}

main() {
  [ "$#" -eq 1 ] || { usage; exit 2; }
  [ "$(id -u)" -eq 0 ] || fail "Run restore as root."

  local backup_id="$1"
  safe_backup_id "$backup_id"

  require_cmd mysql
  require_cmd tar
  require_cmd sha256sum
  require_cmd install
  require_cmd chown
  require_file "$ENV_FILE"
  require_dir "$BACKUP_ROOT"
  require_dir "$APP_DIR"

  local backup_dir="${BACKUP_ROOT}/${backup_id}"
  require_dir "$backup_dir"

  local sql_dump="${backup_dir}/${backup_id}.sql"
  local data_archive="${backup_dir}/${backup_id}-data.tar.gz"
  local storage_archive="${backup_dir}/${backup_id}-storage.tar.gz"
  local app_meta_archive="${backup_dir}/${backup_id}-app-meta.tar.gz"
  local checksums="${backup_dir}/SHA256SUMS"
  local report="${backup_dir}/RESTORE-RUN.log"

  require_file "$sql_dump"
  require_file "$data_archive"
  require_file "$storage_archive"
  require_file "$app_meta_archive"
  require_file "$checksums"

  set -a
  # shellcheck disable=SC1090
  . "$ENV_FILE"
  set +a

  : "${TSPCC_DB_HOST:?TSPCC_DB_HOST is required}"
  : "${TSPCC_DB_PORT:=3306}"
  : "${TSPCC_DB_NAME:?TSPCC_DB_NAME is required}"
  : "${TSPCC_DB_MIGRATION_USER:?TSPCC_DB_MIGRATION_USER is required}"
  : "${TSPCC_DB_MIGRATION_PASSWORD:?TSPCC_DB_MIGRATION_PASSWORD is required}"

  log "Verifying backup checksums: $backup_dir"
  (cd "$backup_dir" && sha256sum -c SHA256SUMS)

  local tmp_dir="${BACKUP_ROOT}/.restore-staging-${backup_id}-$$"
  rm -rf -- "$tmp_dir"
  install -d -m 0700 "$tmp_dir"
  cleanup() {
    if [ "${TSPCC_RESTORE_KEEP_TMP:-}" != "1" ]; then
      rm -rf -- "$tmp_dir"
    fi
  }
  trap cleanup EXIT

  log "Testing archive extraction before deleting current data"
  install -d -m 0755 "$tmp_dir/data" "$tmp_dir/storage" "$tmp_dir/app-meta"
  tar -xzf "$data_archive" -C "$tmp_dir/data"
  tar -xzf "$storage_archive" -C "$tmp_dir/storage"
  tar -xzf "$app_meta_archive" -C "$tmp_dir/app-meta"

  cat >&2 <<EOF_CONFIRM
[RESTORE] Target site:       $SITE_NAME
[RESTORE] App dir:           $APP_DIR
[RESTORE] Backup:            $backup_dir
[RESTORE] Database:          $TSPCC_DB_NAME at $TSPCC_DB_HOST:$TSPCC_DB_PORT
[RESTORE] Data dir:          $DATA_DIR
[RESTORE] Storage dir:       $STORAGE_DIR

This will DELETE current SQL data, $DATA_DIR and $STORAGE_DIR,
then restore them from $backup_id.
EOF_CONFIRM

  if [ "${TSPCC_RESTORE_YES:-}" != "1" ]; then
    printf 'Type RESTORE to continue: ' >&2
    local answer
    read -r answer
    [ "$answer" = "RESTORE" ] || fail "Restore cancelled."
  fi

  {
    echo "restoreStartedAtUtc=$(date -u +%Y-%m-%dT%H:%M:%SZ)"
    echo "backupId=$backup_id"
    echo "appDir=$APP_DIR"
    echo "database=$TSPCC_DB_NAME"
  } > "$report"
  chmod 0600 "$report"

  restore_sql "$sql_dump"

  log "Deleting current runtime file data"
  rm -rf -- "$DATA_DIR" "$STORAGE_DIR"
  install -d -m 0755 "$DATA_DIR" "$STORAGE_DIR"

  log "Restoring data archive"
  tar -xzf "$data_archive" -C "$DATA_DIR"

  log "Restoring storage archive"
  tar -xzf "$storage_archive" -C "$STORAGE_DIR"

  log "Restoring app metadata files"
  tar -xzf "$app_meta_archive" -C "$APP_DIR"

  chown -R "$APP_OWNER" "$DATA_DIR" "$STORAGE_DIR"

  {
    echo "restoreFinishedAtUtc=$(date -u +%Y-%m-%dT%H:%M:%SZ)"
    echo "status=PASS"
  } >> "$report"

  log "Restore completed: $backup_id"
  log "Report: $report"
}

main "$@"
