<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/label_settings"
            android:textSize="22sp"
            android:textStyle="bold" />

        <EditText
            android:id="@+id/baseUrlInput"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:hint="@string/label_base_url"
            android:inputType="textUri" />

        <EditText
            android:id="@+id/fcmEndpointInput"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:hint="@string/label_fcm_endpoint"
            android:inputType="textUri" />

        <androidx.appcompat.widget.SwitchCompat
            android:id="@+id/notifySoundSwitch"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="@string/label_notify_sound" />

        <TextView
            android:id="@+id/notifySoundTypeLabel"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="@string/label_notify_sound_type" />

        <Spinner
            android:id="@+id/notifySoundTypeSpinner"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:entries="@array/notify_sound_options" />

        <androidx.appcompat.widget.SwitchCompat
            android:id="@+id/notifyVibrationSwitch"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="@string/label_notify_vibration" />

        <TextView
            android:id="@+id/notifyVibrationPatternLabel"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="@string/label_notify_vibration_pattern" />

        <Spinner
            android:id="@+id/notifyVibrationPatternSpinner"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:entries="@array/notify_vibration_options" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:text="@string/label_chat_notifications"
            android:textStyle="bold" />

        <androidx.appcompat.widget.SwitchCompat
            android:id="@+id/chatSoundSwitch"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="@string/label_chat_sound" />

        <TextView
            android:id="@+id/chatSoundTypeLabel"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="@string/label_chat_sound_type" />

        <Spinner
            android:id="@+id/chatSoundTypeSpinner"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:entries="@array/notify_sound_options" />

        <androidx.appcompat.widget.SwitchCompat
            android:id="@+id/chatVibrationSwitch"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="@string/label_chat_vibration" />

        <TextView
            android:id="@+id/chatVibrationPatternLabel"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="@string/label_chat_vibration_pattern" />

        <Spinner
            android:id="@+id/chatVibrationPatternSpinner"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:entries="@array/notify_vibration_options" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="@string/label_fcm_token"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/fcmTokenValue"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="@color/gray_700" />

        <TextView
            android:id="@+id/userIdValue"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:textColor="@color/gray_700" />

        <TextView
            android:id="@+id/csrfValue"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:textColor="@color/gray_700" />

        <Button
            android:id="@+id/saveButton"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="@string/label_save" />

        <Button
            android:id="@+id/clearSessionButton"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="@string/label_clear_session" />

        <Button
            android:id="@+id/sendFcmButton"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="@string/label_send_fcm_now" />

        <TextView
            android:id="@+id/settingsStatus"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:textColor="@color/gray_700" />

    </LinearLayout>
</ScrollView>
