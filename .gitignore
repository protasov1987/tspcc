# Node dependencies
node_modules/
dist/
npm-debug.log
yarn-error.log

# Logs
*.log
logs/
*.out
*.err

# Database (не тащим рабочую БД в GitHub)
data/
# если захочешь хранить структуру, можно потом сделать data_example.json и убрать это правило

# Storage
storage/*
!storage/.gitkeep
storage/cards/**

# System trash
.DS_Store
Thumbs.db

# IDE
.vscode/
.idea/
*.swp
*.tmp

# Android / Gradle build artifacts
android-chat/.gradle/
android-chat/.kotlin/
android-chat/**/build/
android-chat/**/intermediates/
android-chat/**/outputs/
android-chat/**/captures/
android-chat/**/.cxx/

# Env files
.env
.env.*

# Service account keys
fcm-service-account.json

# Favicon
favicon.svg

# Android client and its build artifacts
android-chat/

# Local generated artifacts
artifacts/
.codex-npm-test/

# Project documentation and meta files not required by the site runtime
.github/
README.md
REPO_ANALYSIS.md
*.imdx

# Keep only the site help page from docs/
docs/*
!docs/help.html

# Local helper scripts and generated manuals
run_local.bat
docs/*.docx
scripts/generate_user_manual.py

# Unused local asset copy
funny-intro-small.webp

# Temporary generated files
.tmp_index_served.html
